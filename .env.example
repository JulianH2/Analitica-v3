# Copia este archivo a .env y rellena los valores. No versiones .env con datos reales.

# 🔑 Sesión y seguridad
SECRET_KEY=genera_una_clave_secreta_larga_y_aleatoria
JWT_SECRET_KEY=opcional_si_usas_jwt

# 🔐 Azure Entra ID (MSAL) - opcional para login con Microsoft
MSAL_CLIENT_ID=
MSAL_CLIENT_SECRET=
MSAL_AUTHORITY=https://login.microsoftonline.com/<TU_TENANT_ID>

# 🛢️ Base de datos (Azure SQL o SQL Server)
AZURE_SQL_DRIVER=ODBC Driver 18 for SQL Server
AZURE_SQL_SERVER=tu-servidor.database.windows.net
AZURE_SQL_DATABASE=nombre_base_datos
AZURE_SQL_USERNAME=usuario
AZURE_SQL_PASSWORD=contraseña

# 📊 Monitoreo (opcional)
SENTRY_DSN=
