{
  "h_viaje": {
    "table_name": "h_viaje",
    "type": "fact",
    "pk": "no_viaje",
    "description": "Resultados financieros y operativos del viaje. Contiene las métricas calculadas para cada viaje: ingresos (flete), costos totales, utilidad y KPIs como costo por kilómetro e ingreso por viaje.",
    "date_column": "fecha_real_viaje",
    "fields": {
      "subtotal": "decimal",
      "no_viaje": "integer", 
      "id_area": "integer",
      "id_tipo_operacion": "integer",
      "flete": "decimal",
      "otros": "decimal",
      "autopistas": "decimal",
      "maniobras": "decimal",
      "seguro": "decimal",
      "monto_retencion": "decimal",
      "iva_guia": "decimal"
    },
    "joins": {
      "viaje_operativo": {
        "target_table": "d_viaje",
        "type": "INNER",
        "on": "h_viaje.id_area = d_viaje.id_area AND h_viaje.no_viaje = d_viaje.no_viaje"
      },
      "tipo_operacion": {
        "target_table": "d_tipo_operacion",
        "type": "INNER",
        "on": "h_viaje.id_tipo_operacion = d_tipo_operacion.id_tipo_operacion"
      },
      "area": {
        "target_table": "d_area",
        "type": "INNER",
        "on": "h_viaje.id_area = d_area.id_area"
      }
    }
  },
  "d_viaje": {
    "table_name": "d_viaje",
    "type": "dim",
    "pk": "no_viaje",
    "date_column": "fecha_liquidacion",
    "description": "Registro detallado de cada viaje de la flota. Conecta unidad, operador, ruta y datos de rendimiento (kilómetros, combustible, sueldo del operador).",
    "fields": {
      "no_viaje": "integer",
      "ind_cargado": "integer",
      "kms_real": "decimal",
      "kms_viaje": "decimal",
      "lts_real": "decimal",
      "lts_viaje": "decimal",
      "sueldo_operador": "decimal",
      "id_unidad": "string",
      "fecha_liquidacion": "date",
      "id_area": "integer"
    },
    "joins": {
      "ruta": {
        "target_table": "d_ruta",
        "type": "INNER",
        "on": "d_viaje.id_ruta = d_ruta.id_ruta"
      },
      "unidad": {
        "target_table": "d_unidad",
        "type": "INNER",
        "on": "d_viaje.id_unidad = d_unidad.id_unidad"
      },
      "operador": {
        "target_table": "d_personal",
        "type": "INNER",
        "on": "d_viaje.id_operador = d_personal.id_personal"
      },
      "relacion_cp": {
        "target_table": "h_relacion_viaje_cp",
        "type": "INNER",
        "on": "d_viaje.id_area = h_relacion_viaje_cp.id_area AND d_viaje.no_viaje = h_relacion_viaje_cp.no_viaje"
      },
      "viaje_historico": {
        "target_table": "h_viaje",
        "type": "INNER",
        "on": "d_viaje.id_area = h_viaje.id_area AND d_viaje.no_viaje = h_viaje.no_viaje"
      },
      "gastos": {
        "target_table": "h_viajes_gastos_liquidacion",
        "type": "INNER",
        "on": "d_viaje.id_area = h_viajes_gastos_liquidacion.id_area_viaje AND d_viaje.no_viaje = h_viajes_gastos_liquidacion.no_viaje"
      }
    }
  },
  "d_ruta": {
    "table_name": "d_ruta",
    "type": "dim",
    "pk": "id_ruta",
    "label_column": "ruta",
    "description": "Catálogo de rutas operativas por plaza de origen y destino. Incluye distancia oficial en kilómetros y tiempo estimado.",
    "fields": {
      "kms_ruta": "decimal",
      "ruta": "string",
      "id_ruta": "integer",
      "id_origen": "integer",
      "id_destino": "integer"
    },
    "joins": {
      "origen": {
        "target_table": "d_plaza_origen",
        "type": "INNER",
        "on": "d_ruta.id_origen = d_plaza_origen.id_plaza"
      },
      "destino": {
        "target_table": "d_plaza_destino",
        "type": "INNER",
        "on": "d_ruta.id_destino = d_plaza_destino.id_plaza"
      }
    }
  },
  "d_plaza_origen": {
    "table_name": "d_plaza",
    "type": "dim",
    "pk": "id_plaza",
    "description": "Plazas o puntos de origen usados en las rutas de transporte.",
    "fields": { "plaza": "string", "id_plaza": "integer" },
    "joins": {
      "geo_origen": {
        "target_table": "d_plaza_georeferencia_origen",
        "type": "INNER",
        "on": "d_plaza_origen.id_plaza = d_plaza_georeferencia_origen.id_plaza"
      }
    }
  },
  "d_plaza_destino": {
    "table_name": "d_plaza",
    "type": "dim",
    "pk": "id_plaza",
    "description": "Plazas o puntos de destino usados en las rutas de transporte.",
    "fields": { "plaza": "string", "id_plaza": "integer" },
    "joins": {
      "geo_destino": {
        "target_table": "d_plaza_georeferencia_destino",
        "type": "INNER",
        "on": "d_plaza_destino.id_plaza = d_plaza_georeferencia_destino.id_plaza"
      }
    }
  },
  "d_plaza": {
    "table_name": "d_plaza",
    "type": "dim",
    "pk": "id_plaza",
    "description": "Catálogo de plazas (origen/destino) para rutas y análisis geográfico.",
    "fields": {
      "plaza": "string",
      "id_plaza": "integer"
    },
    "joins": {
      "plaza_georeferencia":{
        "target_table": "d_plaza_georeferencia",
        "type": "LEFT",
        "on": "d_plaza.id_plaza = d_plaza_georeferencia.id_plaza"
      }
    }
  },
  "d_plaza_georeferencia": {
    "table_name": "d_plaza_georeferencia",
    "type": "dim",
    "pk": "id_plaza",
    "description": "Coordenadas (lat/lon) de las plazas para mapas y análisis geográfico.",
    "fields": {
      "id_plaza": "integer",
      "latpos": "string",
      "lonpos": "string"
    }
  },
  "d_plaza_georeferencia_origen": {
    "table_name": "d_plaza_georeferencia",
    "type": "dim",
    "pk": "id_plaza",
    "description": "Coordenadas de plazas de origen (alias de d_plaza_georeferencia).",
    "fields": {
      "id_plaza": "integer",
      "latpos": "string",
      "lonpos": "string"
    }
  },
  "d_plaza_georeferencia_destino": {
    "table_name": "d_plaza_georeferencia",
    "type": "dim",
    "pk": "id_plaza",
    "description": "Coordenadas de plazas de destino (alias de d_plaza_georeferencia).",
    "fields": {
      "id_plaza": "integer",
      "latpos": "string",
      "lonpos": "string"
    }
  },
  "h_viajes_gastos_liquidacion": {
    "table_name": "h_viajes_gastos_liquidacion",
    "type": "fact",
    "pk": "id_comp",
    "description": "Desglose de cada partida de gasto asociada a un viaje (combustible, casetas, etc.) proveniente de liquidaciones. Máximo detalle para análisis de costos operativos.", 
    "fields": {
      "id_comp": "integer",
      "monto_concepto": "decimal",
      "monto_combustible": "decimal",
      "monto_caseta_iave": "decimal",
      "monto_caseta_efectivo": "decimal",
      "iva_concepto": "decimal",
      "cantidad": "decimal",
      "id_area_viaje": "integer",
      "no_viaje": "integer",
      "id_area_liq": "integer",
      "no_liquidacion": "integer",
      "id_concepto": "integer",
      "id_gpogasto": "integer"
    },
    "joins": {
      "liquidacion": {
        "target_table": "d_liquidacion",
        "type": "INNER",
        "on": "h_viajes_gastos_liquidacion.id_area_liq = d_liquidacion.id_area AND h_viajes_gastos_liquidacion.no_liquidacion = d_liquidacion.no_liquidacion"
      },
      "concepto": {
        "target_table": "d_trafico_concepto",
        "type": "INNER",
        "on": "h_viajes_gastos_liquidacion.id_concepto = d_trafico_concepto.id_concepto"
      },
      "gpogasto": {
        "target_table": "d_trafico_gpogasto",
        "type": "INNER",
        "on": "h_viajes_gastos_liquidacion.id_gpogasto = d_trafico_gpogasto.id_gpogasto"
      },
      "viaje": {
        "target_table": "d_viaje",
        "type": "INNER",
        "on": "h_viajes_gastos_liquidacion.id_area_viaje = d_viaje.id_area AND h_viajes_gastos_liquidacion.no_viaje = d_viaje.no_viaje"
      }
    }
  },
  "d_unidad": {
    "table_name": "d_unidad",
    "type": "dim",
    "pk": "id_unidad",
    "label_column": "id_unidad",
    "description": "Catálogo maestro de cada unidad de la flota (tractocamión, remolque). Incluye número económico, placas, marca, modelo y fechas de ciclo de vida.",
    "fields": {
      "modelo": "string",
      "id_unidad": "string",
      "id_marca": "integer",
      "id_flota": "integer",
      "id_clasificacion_unidad": "integer",
      "id_tipo_unidad": "integer"
    },
    "joins": {
      "marca": { "target_table": "d_marca_unidad", "type": "LEFT", "on": "d_unidad.id_marca = d_marca_unidad.id_marca_unidad" },
      "tipo_unidad": {
        "target_table": "d_tipo_unidad",
        "type": "INNER",
        "on": "d_unidad.id_tipo_unidad = d_tipo_unidad.id_tipo_unidad"
      },
      "area": {
        "target_table": "d_area",
        "type": "LEFT",
        "on": "d_unidad.id_area = d_area.id_area"
      },
      "flota": { "target_table": "d_flota", "type": "LEFT", "on": "d_unidad.id_flota = d_flota.id_flota" },
      "clasificacion": { 
        "target_table": "d_relacion_clasificacion_tipounidad", 
        "type": "LEFT", 
        "on": "d_unidad.id_clasificacion_unidad = d_relacion_clasificacion_tipounidad.id_clasificacion_unidad AND d_unidad.id_tipo_unidad = d_relacion_clasificacion_tipounidad.id_tipo_unidad" 
      },
      "tipo_operacion": {
        "target_table": "d_tipo_operacion_os",
        "type": "LEFT",
        "on": "d_unidad.id_tipo_operacion = d_tipo_operacion_os.id_tipo_operacion"
      }
    }
  },
  "d_personal": {
    "table_name": "d_personal",
    "type": "dim",
    "pk": "id_personal",
    "label_column": "nombre",
    "description": "Catálogo de operadores (conductores) de la flota. Incluye datos de contacto y vencimiento de licencias.",
    "fields": {
      "id_personal": "integer",
      "nombre": "string"
    }
  },
  "d_trafico_cliente": {
    "table_name": "d_trafico_cliente",
    "type": "dim",
    "pk": "id_cliente",
    "label_column": "nombre_cliente",
    "description": "Catálogo de clientes a los que se presta servicio de transporte. Base para ingresos y rentabilidad por cuenta.",
    "fields": {
      "id_cliente": "integer",
      "nombre_cliente": "string"
    }
  },
  "d_factura": {
    "table_name": "d_factura",
    "type": "dim",
    "pk": "pk_pbi_trafico_guia",
    "description": "Catálogo de facturas emitidas. Relaciona documento fiscal con cliente para análisis de cuentas por cobrar.",
    "fields": {
      "pk_pbi_trafico_guia": "integer",
      "id_cliente": "integer"
    },
    "joins": {
      "cliente": {
        "target_table": "d_trafico_cliente",
        "type": "INNER",
        "on": "d_factura.id_cliente = d_trafico_cliente.id_cliente"
      }
    }
  },
  "d_trafico_guia": {
    "table_name": "d_trafico_guia",
    "type": "dim",
    "pk": "pk_guia",
    "description": "Guía de carga o Carta Porte. Documento que ampara el transporte de mercancías (remitente, destinatario, mercancía).",
    "joins": {
      "estatus_guia": {
        "target_table": "d_estatus_guia",
        "type": "INNER",
        "on": "d_trafico_guia.estatus_guia = d_estatus_guia.id_estatus_guia"
      },
      "guia_proceso_cancelasat": {
        "target_table": "d_guia_proceso_cancelasat",
        "type": "LEFT",
        "on": "d_trafico_guia.num_guia = d_guia_proceso_cancelasat.factura"
      },
      "cliente": {
        "target_table": "d_trafico_cliente",
        "type": "INNER",
        "on": "d_trafico_guia.id_cliente = d_trafico_cliente.id_cliente"
      }
    }
  },
  "h_relacion_viaje_cp": {
    "table_name": "h_relacion_viaje_cp",
    "type": "fact",
    "pk": "id_relacion",
    "description": "Relación entre un viaje y las Cartas Porte (guías) asociadas. Conecta operación logística con documentación.",
    "joins": {
      "guia": {
        "target_table": "d_trafico_guia",
        "type": "INNER",
        "on": "h_relacion_viaje_cp.id_area_guia = d_trafico_guia.id_area AND h_relacion_viaje_cp.no_guia = d_trafico_guia.no_guia"
      },
      "viaje": {
        "target_table": "d_viaje",
        "type": "INNER",
        "on": "h_relacion_viaje_cp.id_area = d_viaje.id_area AND h_relacion_viaje_cp.no_viaje = d_viaje.no_viaje"
      }
    }
  },
  "d_trafico_concepto": {
    "table_name": "d_trafico_concepto",
    "type": "dim",
    "pk": "id_concepto",
    "label_column": "descripcion_concepto",
    "description": "Conceptos de gasto y deducciones en liquidaciones de viaje (peajes, viáticos, etc.).",
    "fields": {
      "concepto": "string",
      "id_concepto": "integer",
      "id_clasificacion": "integer"
    },
    "joins": {
      "clasificacion": {
        "target_table": "d_trafico_concepto_clasificacion",
        "type": "INNER",
        "on": "d_trafico_concepto.id_clasificacion = d_trafico_concepto_clasificacion.id_clasificacion"
      }
    }
  },
  "d_trafico_concepto_clasificacion": {
    "table_name": "d_trafico_concepto_clasificacion",
    "type": "dim",
    "pk": "id_clasificacion",
    "description": "Clasificación de alto nivel de conceptos de gasto (Combustible, Casetas, Viáticos, Mantenimiento).",
    "fields": {
      "nombre": "string",
      "id_clasificacion": "integer"
    }
  },
  "d_meta_tiempo": {
    "table_name": "d_meta_tiempo",
    "description": "Metas y objetivos (plan/presupuesto) por fecha para KPIs: ingresos, costos, km, combustible, cartera, taller, etc.",
    "type": "fact",
    "pk": "fecha",
    "date_column": "fecha",
    "fields": {
      "meta_ingreso_viaje": "decimal",
      "meta_costos_viaje": "decimal",
      "meta_kms_recorridos": "decimal",
      "meta_litros_combustible": "decimal",
      "meta_promedio_dias_cartera": "decimal",
      "meta_promedio_dias_pago": "decimal",
      "meta_costo_tallerinterno": "decimal",
      "meta_costo_tallerexterno": "decimal",
      "meta_costo_tallerllantas": "decimal",
      "meta_costo_mtto_x_km": "decimal",
      "meta_valorizacion_almacen": "decimal",
      "fecha": "date"
    }
  },
  "d_empresa": {
    "table_name": "d_empresa",
    "description": "Catálogo maestro de empresas del grupo. Nivel jerárquico superior al área/sucursal.",
    "type": "dim",
    "pk": "id_empresa",
    "label_column": "empresa",
    "fields": {
      "id_empresa": "integer",
      "empresa": "string",
      "estatus_empresa": "string",
      "rfc": "string"
    }
  },
  "d_area": {
    "table_name": "d_area",
    "description": "Catálogo de áreas geográficas u operativas (sucursales, zonas). Base para análisis por ubicación.",
    "type": "dim",
    "pk": "id_area",
    "label_column": "area",
    "fields": {
      "id_area": "integer",
      "id_empresa": "integer",
      "no_abrev_area": "string",
      "area": "string"
    },
    "joins": {
      "empresa": {
        "target_table": "d_empresa",
        "type": "INNER",
        "on": "d_area.id_empresa = d_empresa.id_empresa"
      }
    }
  },
  "d_tipo_operacion": {
    "table_name": "d_tipo_operacion",
    "description": "Tipos de operación logística (Carga General, Especializada, Refinados, Contenedor, etc.).",
    "type": "dim",
    "pk": "id_tipo_operacion",
    "fields": {
      "tipo_operacion": "string",
      "id_tipo_operacion": "integer"
    },
    "label_column": "tipo_operacion"
  },
  "d_liquidacion": {
    "table_name": "d_liquidacion",
    "type": "dim",
    "pk": "pk_liquidacion",
    "description": "Registro de cada liquidación: conciliación de gastos de viaje del operador contra anticipo (saldo a favor del operador o de la empresa).",
    "business_key": [
      "id_area",
      "no_liquidacion"
    ]
  },
  "d_trafico_gpogasto": {
    "table_name": "d_trafico_gpogasto",
    "type": "dim",
    "pk": "id_gpogasto",
    "description": "Grupos de gasto de alto nivel que agrupan conceptos (Combustibles, Peajes, Mantenimiento) para análisis financiero."
  },
  "d_tipo_unidad": {
    "table_name": "d_tipo_unidad",
    "type": "dim",
    "pk": "id_tipo_unidad",
    "label_column": "tipo_unidad",
    "description": "Catálogo de tipos de vehículo (tractocamión, remolque, torton, etc.) para análisis por categoría.",
    "fields": {
      "id_tipo_unidad": "integer",
      "tipo_unidad": "string"
    }
  },
  "d_estatus_guia": {
    "table_name": "d_estatus_guia",
    "type": "dim",
    "pk": "id_estatus_guia",
    "description": "Estados de una guía de transporte (En tránsito, Entregada, etc.)."
  },
  "d_guia_proceso_cancelasat": {
    "table_name": "d_guia_proceso_cancelasat",
    "type": "dim",
    "pk": "factura",
    "description": "Relación de guías con proceso de cancelación SAT (facturación electrónica)."
  },
  "d_marca_unidad": {
    "table_name": "d_marca_unidad",
    "type": "dim",
    "pk": "id_marca_unidad",
    "description": "Catálogo de marcas de vehículos de la flota. Análisis por fabricante.",
    "fields": {
      "marca_unidad": "string",
      "id_marca_unidad": "integer"
    }
  },
  "h_factura_saldo": {
    "table_name": "h_factura_saldo",
    "type": "fact",
    "pk": "fk_factura", 
    "date_column": "fecha_factura",
    "description": "Histórico de saldos y montos facturados por factura: facturado, cobrado, notas de crédito/cargo y saldo acumulado.",
    "fields": {
      "fk_factura": "integer",
      "id_area": "integer",
      "id_rango_vencimiento": "integer",
      "monto_facturado_mx": "decimal",
      "monto_ncred_acum_mx": "decimal",
      "monto_ncred_mx": "decimal",
      "monto_ncargo_mx": "decimal",
      "monto_ncargo_acum_mx": "decimal",
      "monto_cobrado_mx": "decimal", 
      "monto_cobrado_acum_mx": "decimal", 
      "monto_saldo_acum_mx": "decimal",
      "orden": "integer",
      "fecha_factura": "date",
      "fecha_vencimiento": "date"
    },
    "joins": {
      "area": {
        "target_table": "d_area",
        "type": "INNER",
        "on": "h_factura_saldo.id_area = d_area.id_area"
      },
      "factura": {
        "target_table": "d_factura",
        "type": "INNER",
        "on": "h_factura_saldo.fk_factura = d_factura.pk_pbi_trafico_guia"
      },
      "rango_vencimiento": {
        "target_table": "d_cxc_rango_vencimiento",
        "type": "INNER",
        "on": "h_factura_saldo.id_rango_vencimiento = d_cxc_rango_vencimiento.id_rango_vencimiento"
      }
    }
  },
  "d_nota_credito": {
    "table_name": "d_nota_credito",
    "type": "dim",
    "pk": "num_ncredito",
    "date_column": "fecha",
    "description": "Notas de crédito aplicadas a facturas (devoluciones o bonificaciones).",
    "fields": {
      "num_ncredito": "integer",
      "monto_credito": "decimal",
      "monto_retencion": "decimal",
      "estatus": "string",
      "fecha": "date"
    }
  },
  "d_nota_cargo": {
    "table_name": "d_nota_cargo",
    "type": "dim",
    "pk": "num_ncargo",
    "date_column": "fecha",
    "description": "Notas de cargo aplicadas a facturas (cargos adicionales).",
    "fields": {
      "num_ncargo": "integer",
      "monto_cargo": "decimal",
      "monto_retencion": "decimal",
      "estatus": "string",
      "fecha": "date"
    }
  },
  "h_factura_cobrado": {
    "table_name": "h_factura_cobrado",
    "type": "fact",
    "pk": "id_cobro", 
    "date_column": "fecha_consulta",
    "description": "Registro de cobros aplicados a facturas (monto y fecha de cobro).",
    "fields": {
      "monto_cobrado": "decimal",
      "fecha_consulta": "date",
      "fk_factura": "integer"
